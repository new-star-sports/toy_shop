# ============================================================================
# NewStarSports — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your real credentials.
# NEVER commit .env.local to version control.
# ============================================================================

# ── SUPABASE ─────────────────────────────────────────────────────────────────
# Create project at https://supabase.com — use EU/Middle East region for PDPL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── MYFATOORAH (Primary Payment Gateway — Kuwait KNET) ───────────────────────
# Apply at https://myfatoorah.com — 7-14 business day onboarding
MYFATOORAH_API_KEY_TEST=your-myfatoorah-test-api-key
MYFATOORAH_API_KEY_LIVE=your-myfatoorah-live-api-key
MYFATOORAH_API_URL_TEST=https://apitest.myfatoorah.com
MYFATOORAH_API_URL_LIVE=https://api.myfatoorah.com
MYFATOORAH_WEBHOOK_SECRET=your-myfatoorah-webhook-secret

# ── TAP PAYMENTS (Secondary/Backup Gateway) ──────────────────────────────────
# Apply at https://tap.company
TAP_SECRET_KEY_TEST=your-tap-test-secret-key
TAP_SECRET_KEY_LIVE=your-tap-live-secret-key
TAP_PUBLIC_KEY_TEST=your-tap-test-public-key
TAP_PUBLIC_KEY_LIVE=your-tap-live-public-key
TAP_WEBHOOK_SECRET=your-tap-webhook-secret

# ── ALGOLIA (Search — Arabic stemming support) ───────────────────────────────
# Apply at https://www.algolia.com
NEXT_PUBLIC_ALGOLIA_APP_ID=your-algolia-app-id
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=your-algolia-search-only-key
ALGOLIA_ADMIN_KEY=your-algolia-admin-api-key
ALGOLIA_INDEX_NAME=newstarsports_products

# ── RESEND (Transactional Emails) ────────────────────────────────────────────
# Apply at https://resend.com
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=orders@newstarsports.com
RESEND_FROM_NAME=NewStarSports

# ── SENTRY (Error Tracking) ─────────────────────────────────────────────────
# Create projects at https://sentry.io — one for storefront, one for admin
NEXT_PUBLIC_SENTRY_DSN_STOREFRONT=https://your-dsn@sentry.io/storefront-project-id
NEXT_PUBLIC_SENTRY_DSN_ADMIN=https://your-dsn@sentry.io/admin-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT_STOREFRONT=newstarsports-storefront
SENTRY_PROJECT_ADMIN=newstarsports-admin

# ── POSTHOG (Product Analytics) ─────────────────────────────────────────────
# Apply at https://posthog.com (cloud or self-hosted for PDPL)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# ── APP CONFIG ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://newstarsports.com
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_SUPPORTED_LOCALES=en,ar

# ── VERCEL (Auto-set by Vercel, but needed for local dev) ────────────────────
# VERCEL_URL is auto-set on Vercel deployments
# For local: http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=http://localhost:3000

# ── NOTE ─────────────────────────────────────────────────────────────────────
# Rate limiting: handled by Vercel Pro edge rate limiting (no Redis needed)
# Guest cart: stored in signed encrypted cookie (no Redis needed)
# Cron jobs: all run via Supabase pg_cron (no CRON_SECRET needed)

